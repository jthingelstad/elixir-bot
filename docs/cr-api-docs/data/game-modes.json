  "modeFamilies": [
    {
      "id": "trophy_road",
      "displayName": "Trophy Road / Arenas",
      "classification": "permanent_progression",
      "apiSignals": [
        "Player.trophies",
        "Player.bestTrophies",
        "Player.arena",
        "Battle.type=PvP",
        "Battle.gameMode.name=Ladder",
        "PlayerBattleData.trophyChange"
      ],
      "notes": [
        "Standard ladder progression and arena unlocks.",
        "Do not use Trophy Road fields as a proxy for all player activity."
      ],
      "sourceUrls": [
        "https://clashroyale.fandom.com/wiki/Arenas",
        "https://clashroyale.fandom.com/wiki/Trophies"
      ]
    },
    {
      "id": "ranked_path_of_legend",
      "displayName": "Ranked / Path of Legend",
      "classification": "permanent_ranked_progression",
      "apiSignals": [
        "Player.currentPathOfLegendSeasonResult",
        "Player.lastPathOfLegendSeasonResult",
        "Player.bestPathOfLegendSeasonResult",
        "Battle.type=pathOfLegend",
        "Battle.leagueNumber",
        "GET /locations/{locationId}/pathoflegend/players",
        "GET /locations/global/pathoflegend/{seasonId}/rankings/players"
      ],
      "notes": [
        "Use Ranked for current player-facing wording; the API still uses pathoflegend names.",
        "Ultimate Champion ranking uses rating exposed as eloRating on ranking endpoints."
      ],
      "sourceUrls": ["https://clashroyale.fandom.com/wiki/Ranked"]
    },
    {
      "id": "merge_tactics",
      "displayName": "Merge Tactics",
      "classification": "side_mode_progression",
      "apiSignals": [
        "Player.progress",
        "GET /leaderboards",
        "GET /leaderboard/{leaderboardId}"
      ],
      "notes": [
        "Four-player auto-battler side mode with draft/deploy/merge rounds.",
        "Progress uses side-mode keys and should not be inferred from Player.trophies."
      ],
      "sourceUrls": [
        "https://clashroyale.fandom.com/wiki/Merge_Tactics",
        "https://clashroyale.fandom.com/wiki/Trophies"
      ]
    },
    {
      "id": "clan_wars_river_race",
      "displayName": "Clan Wars / River Race",
      "classification": "clan_competition",
      "apiSignals": [
        "GET /clans/{clanTag}/currentriverrace",
        "GET /clans/{clanTag}/riverracelog",
        "Battle.type=riverRacePvP",
        "Battle.type=riverRaceDuel",
        "Battle.type=riverRaceDuelColosseum",
        "Battle.type=boatBattle"
      ],
      "notes": [
        "Use periodType to distinguish training, warDay, and colosseum phases.",
        "Use participant decksUsed and decksUsedToday for participation tracking."
      ],
      "sourceUrls": ["https://clashroyale.fandom.com/wiki/Clan_Wars"]
    },
    {
      "id": "events_and_special_challenges",
      "displayName": "Events / Special Event Challenges",
      "classification": "temporary_or_rotating_rules",
      "apiSignals": [
        "GET /events",
        "Battle.eventTag",
        "Battle.type=trail",
        "Battle.gameMode",
        "Battle.deckSelection",
        "Battle.modifiers"
      ],
      "notes": [
        "Includes draft, elixir, environment, locked-card, mirror, and other rotating rule variants.",
        "Use live events and battle logs rather than hardcoded availability."
      ],
      "sourceUrls": [
        "https://clashroyale.fandom.com/wiki/Events",
        "https://clashroyale.fandom.com/wiki/Tournament/Special_Event_Challenges"
      ]
    },
    {
      "id": "tournaments",
      "displayName": "Tournaments / Global Tournaments / Victory Challenges",
      "classification": "competitive_event",
      "apiSignals": [
        "GET /tournaments",
        "GET /tournaments/{tournamentTag}",
        "GET /globaltournaments",
        "GET /locations/global/rankings/tournaments/{tournamentTag}",
        "Battle.type=tournament",
        "Battle.tournamentTag"
      ],
      "notes": [
        "Player-created tournaments, global tournaments, and victory challenges have different API surfaces.",
        "Mega Draft and other challenge formats may not use the player's normal currentDeck."
      ],
      "sourceUrls": ["https://clashroyale.fandom.com/wiki/Tournament"]
    },
    {
      "id": "two_v_two",
      "displayName": "2v2",
      "classification": "team_mode",
      "apiSignals": [
        "Battle.team.length=2",
        "Battle.opponent.length=2",
        "Battle.type=clanMate2v2",
        "Battle.gameMode.name=TeamVsTeam"
      ],
      "notes": [
        "Normal 2v2 does not put Trophy Road trophies at risk.",
        "Outcome logic should still use the first team entry because teammates share the result."
      ],
      "sourceUrls": ["https://clashroyale.fandom.com/wiki/2v2"]
    },
    {
      "id": "friendly_and_training",
      "displayName": "Friendly Battle / Training Camp / Card Delivery",
      "classification": "practice_or_tutorial",
      "apiSignals": [
        "Battle.type=clanMate",
        "Battle.type=friendly",
        "Battle.gameMode.name=Friendly",
        "GET /events"
      ],
      "notes": [
        "Friendly battles are practice battles against friends or clanmates.",
        "Training Camp and Card Delivery are not normal progression surfaces."
      ],
      "sourceUrls": [
        "https://clashroyale.fandom.com/wiki/Friendly_Battle",
        "https://clashroyale.fandom.com/wiki/Training_Camp",
        "https://clashroyale.fandom.com/wiki/Card_Delivery"
      ]
    }
  ],
